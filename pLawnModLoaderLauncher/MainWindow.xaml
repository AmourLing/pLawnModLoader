<Window
    x:Class="pLawnModLoaderLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="pLawnModLoader 启动器"
    Width="800"
    Height="550"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  游戏路径选择  -->
        <Grid Grid.Row="0" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Margin="0,0,5,0"
                VerticalAlignment="Center"
                FontWeight="Bold"
                Text="游戏路径:" />
            <TextBox
                x:Name="GamePathTextBox"
                Grid.Column="1"
                Height="25"
                VerticalAlignment="Center"
                IsReadOnly="True"
                Text="未选择" />
            <Button
                x:Name="BrowseButton"
                Grid.Column="2"
                Width="60"
                Margin="5,0,0,0"
                Click="BrowseButton_Click"
                Content="浏览" />
        </Grid>

        <!--  主内容  -->
        <Grid Grid.Row="1" Margin="10,0,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  方案选择栏  -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    Margin="0,0,5,0"
                    VerticalAlignment="Center"
                    FontWeight="Bold"
                    Text="补丁方案:" />
                <ComboBox
                    x:Name="SchemeComboBox"
                    Grid.Column="1"
                    Height="25"
                    SelectionChanged="SchemeComboBox_SelectionChanged" />
                <Button
                    x:Name="SaveSchemeButton"
                    Grid.Column="2"
                    Margin="5,0,5,0"
                    Padding="8,3"
                    Click="SaveScheme_Click"
                    Content="保存当前方案" />
                <Button
                    x:Name="NewSchemeButton"
                    Grid.Column="3"
                    Padding="8,3"
                    Click="NewScheme_Click"
                    Content="新建方案" />
            </Grid>

            <!--  补丁列表  -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="Bold"
                        Text="可用补丁:" />
                    <Button
                        x:Name="ToggleAllButton"
                        Grid.Column="1"
                        Padding="10,5"
                        Background="#66CCFF"
                        Click="ToggleAll_Click"
                        Content="一键开启所有"
                        Foreground="White" />
                </Grid>

                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,5,0,0"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PatchesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,2" CornerRadius="5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#50EE0000" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                    <Setter Property="Background" Value="#5066CCFF" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="8,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="Medium"
                                            Text="{Binding PatchName}" />

                                        <!--  说明按钮  -->
                                        <Button
                                            Grid.Column="1"
                                            Margin="5,0,0,0"
                                            Padding="5,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ShowPatchReadme_Click"
                                            Content="[?]"
                                            FontSize="11"
                                            Tag="{Binding SourcePath}"
                                            ToolTip="查看说明" />

                                        <!--  配置按钮  -->
                                        <Button
                                            Grid.Column="2"
                                            Margin="5,0,0,0"
                                            Padding="5,2"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Click="ShowPatchConfig_Click"
                                            Content="⚙"
                                            FontSize="12"
                                            Tag="{Binding SourcePath}"
                                            ToolTip="配置补丁" />

                                        <CheckBox
                                            Grid.Column="3"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center"
                                            IsChecked="{Binding IsEnabled, Mode=TwoWay}">
                                            <CheckBox.Content>
                                                <TextBlock>
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#EE0000" />
                                                            <Setter Property="Text" Value="未启用" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                    <Setter Property="Foreground" Value="#66CCFF" />
                                                                    <Setter Property="Text" Value="已启用" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!--  操作按钮区域  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,10,0,0"
                HorizontalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    x:Name="UpdateButton"
                    Width="80"
                    Height="35"
                    Margin="5"
                    Click="UpdateButton_Click"
                    Content="更新" />
                <Button
                    x:Name="UpdateAndLaunchButton"
                    Width="120"
                    Height="35"
                    Margin="5"
                    Click="UpdateAndLaunchButton_Click"
                    Content="更新并启动"
                    FontWeight="Bold" />
                <Button
                    x:Name="OpenModsFolderButton"
                    Width="120"
                    Height="35"
                    Margin="5"
                    Click="OpenModsFolderButton_Click"
                    Content="打开补丁文件夹" />
                <Button
                    x:Name="RefreshButton"
                    Width="100"
                    Height="35"
                    Margin="5"
                    Click="RefreshButton_Click"
                    Content="刷新补丁列表" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>