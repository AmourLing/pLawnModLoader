<Window
    x:Class="pLawnModLoaderLauncher.JsonEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="编辑JSON"
    Width="600"
    Height="450"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="ModeText"
            Grid.Row="0"
            Margin="0,0,0,5"
            FontWeight="Bold" />

        <!--  文本编辑模式  -->
        <TextBox
            x:Name="JsonTextBox"
            Grid.Row="1"
            AcceptsReturn="True"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto"
            Visibility="Collapsed" />

        <!--  表格编辑模式  -->
        <DataGrid
            x:Name="DynamicDataGrid"
            Grid.Row="1"
            AutoGenerateColumns="False"
            CanUserAddRows="True"
            CanUserDeleteRows="True"
            Visibility="Collapsed" />

        <StackPanel
            Grid.Row="2"
            Margin="0,10,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Click="OkButton_Click"
                Content="确定" />
            <Button
                Width="80"
                Height="30"
                Click="CancelButton_Click"
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>