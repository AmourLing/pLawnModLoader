<Window
    x:Class="pLawnModLoaderLauncher.pLModsConfigWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:pLawnModLoaderLauncher"
    Title="补丁配置"
    Width="600"
    Height="450"
    MinWidth="400"
    MinHeight="300"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <local:StringToBoolConverter x:Key="StringToBoolConverter" />

        <!--  字符串模板（默认显示）  -->
        <DataTemplate x:Key="StringTemplate">
            <TextBlock VerticalAlignment="Center" Text="{Binding Value}" />
        </DataTemplate>

        <!--  整数模板：加减按钮  -->
        <DataTemplate x:Key="IntTemplate">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <Button
                    Width="20"
                    Click="IntDecrement_Click"
                    Content="-"
                    Tag="{Binding}" />
                <TextBlock
                    Margin="5,0"
                    VerticalAlignment="Center"
                    Text="{Binding Value}" />
                <Button
                    Width="20"
                    Click="IntIncrement_Click"
                    Content="+"
                    Tag="{Binding}" />
            </StackPanel>
        </DataTemplate>

        <!--  布尔模板：复选框  -->
        <DataTemplate x:Key="BoolTemplate">
            <CheckBox IsChecked="{Binding Value, Converter={StaticResource StringToBoolConverter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
              VerticalAlignment="Center"/>
        </DataTemplate>

        <!--  对象模板：编辑按钮  -->
        <DataTemplate x:Key="ObjectTemplate">
            <Button
                Click="EditObject_Click"
                Content="编辑"
                Tag="{Binding}" />
        </DataTemplate>

        <!--  数组模板：编辑按钮  -->
        <DataTemplate x:Key="ArrayTemplate">
            <Button
                Click="EditObject_Click"
                Content="编辑"
                Tag="{Binding}" />
        </DataTemplate>

        <!--  模板选择器  -->
        <local:ConfigItemTemplateSelector
            x:Key="TemplateSelector"
            ArrayTemplate="{StaticResource ArrayTemplate}"
            BoolTemplate="{StaticResource BoolTemplate}"
            IntTemplate="{StaticResource IntTemplate}"
            ObjectTemplate="{StaticResource ObjectTemplate}"
            StringTemplate="{StaticResource StringTemplate}" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,5"
            FontWeight="Bold"
            Text="配置项（直接编辑键和值）" />

        <DataGrid
            x:Name="ConfigDataGrid"
            Grid.Row="1"
            Margin="0,0,0,10"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            ItemsSource="{Binding}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Key}"
                    Header="键" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Value}"
                    Header="值" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Type}"
                    Header="类型"
                    IsReadOnly="True" />
                <!--  操作列：使用模板选择器动态显示控件  -->
                <DataGridTemplateColumn Width="100" Header="操作">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentControl Content="{Binding}" ContentTemplateSelector="{StaticResource TemplateSelector}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel
            Grid.Row="2"
            Margin="0,0,0,10"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Click="AddItem_Click"
                Content="添加项" />
            <Button
                Width="80"
                Height="30"
                Click="DeleteItem_Click"
                Content="删除选中" />
        </StackPanel>

        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="SaveButton"
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Click="SaveButton_Click"
                Content="保存" />
            <Button
                x:Name="CancelButton"
                Width="80"
                Height="30"
                Click="CancelButton_Click"
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>