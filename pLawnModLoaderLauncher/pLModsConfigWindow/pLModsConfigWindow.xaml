<Window
    x:Class="pLawnModLoaderLauncher.pLModsConfigWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="补丁配置"
    Width="600"
    Height="450"
    MinWidth="400"
    MinHeight="300"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,5"
            FontWeight="Bold"
            Text="配置项（直接编辑键和值）" />

        <DataGrid
            x:Name="ConfigDataGrid"
            Grid.Row="1"
            Margin="0,0,0,10"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            ItemsSource="{Binding}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Key}"
                    Header="键" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Value}"
                    Header="值" />
                <DataGridTextColumn
                    Width="80"
                    Binding="{Binding Type}"
                    Header="类型"
                    IsReadOnly="True" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel
            Grid.Row="2"
            Margin="0,0,0,10"
            HorizontalAlignment="Left"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Click="AddItem_Click"
                Content="添加项" />
            <Button
                Width="80"
                Height="30"
                Click="DeleteItem_Click"
                Content="删除选中" />
        </StackPanel>

        <StackPanel
            Grid.Row="3"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="SaveButton"
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Click="SaveButton_Click"
                Content="保存" />
            <Button
                x:Name="CancelButton"
                Width="80"
                Height="30"
                Click="CancelButton_Click"
                Content="取消"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>