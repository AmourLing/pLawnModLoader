<Window
    x:Class="pLawnModLoaderLauncher.ReadmeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="补丁说明"
    Width="700"
    Height="500"
    MinWidth="400"
    MinHeight="300"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox
            x:Name="ReadmeText"
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="8"
            Background="#FAFAFA"
            BorderBrush="#DDD"
            BorderThickness="1"
            FontFamily="Microsoft YaHei"
            FontSize="14"
            HorizontalScrollBarVisibility="Auto"
            IsReadOnly="True"
            TextOptions.TextFormattingMode="Display"
            TextOptions.TextRenderingMode="ClearType"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="CopyButton"
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Click="CopyButton_Click"
                Content="复制内容"
                ToolTip="将说明文本复制到剪贴板" />
            <Button
                x:Name="CloseButton"
                Width="80"
                Height="30"
                Click="CloseButton_Click"
                Content="关闭"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</Window>